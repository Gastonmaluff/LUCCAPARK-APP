rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userRole() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        ? firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function canManageBackups() {
      return signedIn()
        && (
          request.auth.uid == 'SXaYNYcKFXP8FZDCk3DP38EyP903'
          || userRole() in ['admin', 'owner', 'dueno', 'dueño', 'socio', 'partner']
        );
    }

    function validImage(maxMb) {
      return request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size <= maxMb * 1024 * 1024;
    }

    function validExpenseReceipt() {
      return request.resource != null
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        )
        && request.resource.size <= 8 * 1024 * 1024;
    }

    function validClosurePdf() {
      return request.resource != null
        && request.resource.contentType == 'application/pdf'
        && request.resource.size <= 10 * 1024 * 1024;
    }

    match /expense-receipts/{userId}/{fileName} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn()
        && request.auth.uid == userId
        && validExpenseReceipt();
      allow update, delete: if false;
    }

    match /financial-closures/{closureId}/{fileName} {
      allow read: if signedIn();
      allow create: if signedIn() && validClosurePdf();
      allow update, delete: if false;
    }

    match /canteen-products/{allPaths=**} {
      allow read: if true;
      allow create, update: if signedIn() && validImage(5);
      allow delete: if false;
    }

    match /event-tv-images/{allPaths=**} {
      allow read: if true;
      allow create, update: if signedIn() && validImage(8);
      allow delete: if false;
    }

    match /public-page-images/{allPaths=**} {
      allow read: if true;
      allow create, update: if signedIn() && validImage(8);
      allow delete: if false;
    }

    match /backups/{allPaths=**} {
      allow read, create: if canManageBackups();
      allow update, delete: if false;
    }

    match /decoration-images/{allPaths=**} {
      allow read: if signedIn();
      allow create, update: if signedIn() && validImage(8);
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
