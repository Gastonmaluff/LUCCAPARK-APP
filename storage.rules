rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userProfile() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function role() {
      return hasUserProfile() ? userProfile().data.role : '';
    }

    function isKnownRole(value) {
      return value in ['admin', 'socio', 'encargado_eventos', 'recepcion', 'cantina'];
    }

    function isActiveUser() {
      return hasUserProfile()
        && userProfile().data.isActive == true
        && isKnownRole(role());
    }

    function hasRole(allowedRoles) {
      return isActiveUser() && role() in allowedRoles;
    }

    function canViewCanteenFiles() {
      return hasRole(['admin', 'socio', 'encargado_eventos', 'recepcion', 'cantina']);
    }

    function canManageCanteenProducts() {
      return hasRole(['admin', 'socio']);
    }

    function canManageEventTv() {
      return hasRole(['admin', 'socio', 'encargado_eventos']);
    }

    function canManagePublicContent() {
      return hasRole(['admin', 'socio']);
    }

    function canViewFinance() {
      return hasRole(['admin', 'socio']);
    }

    function canManageBackups() {
      return hasRole(['admin', 'socio']);
    }

    function canViewDecorations() {
      return hasRole(['admin', 'socio', 'encargado_eventos']);
    }

    function canManageDecorations() {
      return hasRole(['admin', 'socio']);
    }

    function hasAllowedImageType() {
      return request.resource.contentType in ['image/png', 'image/jpeg', 'image/webp'];
    }

    function validImage(maxBytes) {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= maxBytes
        && hasAllowedImageType();
    }

    function validExpenseReceipt() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 8 * 1024 * 1024
        && request.resource.contentType in [
          'image/png', 'image/jpeg', 'image/webp', 'application/pdf'
        ];
    }

    function validClosurePdf() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    function validBackupJson() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 50 * 1024 * 1024
        && request.resource.contentType == 'application/json';
    }

    match /expense-receipts/{userId}/{fileName} {
      allow read: if isActiveUser()
        && (request.auth.uid == userId || canViewFinance());
      allow create: if isActiveUser()
        && request.auth.uid == userId
        && resource == null
        && validExpenseReceipt();
      allow update, delete: if false;
    }

    match /financial-closures/{closureId}/{fileName} {
      allow read: if canViewFinance();
      allow create: if canViewFinance() && resource == null && validClosurePdf();
      allow update, delete: if false;
    }

    match /canteen-products/{productId}/{fileName} {
      allow read: if canViewCanteenFiles();
      allow create: if canManageCanteenProducts()
        && resource == null
        && validImage(5 * 1024 * 1024);
      allow update, delete: if false;
    }

    match /event-tv-images/{eventId}/{fileName} {
      allow read: if true;
      allow create: if canManageEventTv()
        && resource == null
        && validImage(5 * 1024 * 1024);
      allow update, delete: if false;
    }

    match /public-page-images/{folder}/{fileName} {
      allow read: if folder in ['hero', 'installations'];
      allow create: if folder in ['hero', 'installations']
        && canManagePublicContent()
        && resource == null
        && validImage(8 * 1024 * 1024);
      allow update, delete: if false;
    }

    match /backups/{backupType}/{fileName} {
      allow read: if backupType in ['manual', 'automatic'] && canManageBackups();
      allow create: if backupType in ['manual', 'automatic']
        && canManageBackups()
        && resource == null
        && validBackupJson();
      allow update, delete: if false;
    }

    match /decoration-images/{decorationId}/{fileName} {
      allow read: if canViewDecorations();
      allow create, update: if canManageDecorations() && validImage(8 * 1024 * 1024);
      allow delete: if canManageDecorations();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
