rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isBootstrapOwner() {
      return signedIn() && request.auth.uid == 'SXaYNYcKFXP8FZDCk3DP38EyP903';
    }

    function hasProfile() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function userProfile() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function role() {
      return hasProfile() ? userProfile().data.role : '';
    }

    function isActiveUser() {
      return isBootstrapOwner()
        || (hasProfile() && userProfile().data.isActive != false);
    }

    function isAdmin() {
      return isBootstrapOwner()
        || (isActiveUser() && role() in ['admin', 'owner', 'dueno', 'dueño']);
    }

    function isPartner() {
      return isActiveUser() && role() in ['socio', 'partner'];
    }

    function isEventManager() {
      return isActiveUser() && role() in ['encargado_eventos', 'event_manager'];
    }

    function isReception() {
      return isActiveUser() && role() in ['recepcion', 'reception'];
    }

    function isCanteen() {
      return isActiveUser() && role() in ['cantina', 'canteen'];
    }

    function canManageProductImages() {
      return isAdmin() || isPartner() || isCanteen();
    }

    function canManageEventTvImages() {
      return isAdmin() || isPartner() || isEventManager();
    }

    function canManageExpenseReceipts() {
      return isAdmin() || isPartner() || isEventManager() || isReception() || isCanteen();
    }

    function canUploadOwnExpenseReceipt(userId) {
      return signedIn()
        && request.auth.uid == userId
        && isActiveUser()
        && canManageExpenseReceipts();
    }

    function canReadExpenseReceipt(userId) {
      return signedIn()
        && (isAdmin() || isPartner() || (request.auth.uid == userId && isActiveUser()));
    }

    function canManageFinancialClosures() {
      return isAdmin() || isPartner();
    }

    function validProductImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;
    }

    function validExpenseReceipt() {
      return request.resource != null
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        )
        && request.resource.size <= 8 * 1024 * 1024;
    }

    match /canteen-products/{allPaths=**} {
      allow read: if true;
      allow create, update: if canManageProductImages() && validProductImage();
      allow delete: if canManageProductImages();
    }

    match /event-tv-images/{allPaths=**} {
      allow read: if true;
      allow create, update: if canManageEventTvImages() && validProductImage();
      allow delete: if canManageEventTvImages();
    }

    match /expense-receipts/{userId}/{fileName} {
      allow read: if canReadExpenseReceipt(userId);
      allow create: if canUploadOwnExpenseReceipt(userId) && validExpenseReceipt();
      allow update, delete: if false;
    }

    match /financial-closures/{allPaths=**} {
      allow read: if canManageFinancialClosures();
      allow create, update: if canManageFinancialClosures()
        && request.resource != null
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
