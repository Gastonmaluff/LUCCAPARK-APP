rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return hasUserProfile() ? userDoc().data.role : '';
    }

    function isKnownRole(value) {
      return value in ['admin', 'socio', 'encargado_eventos', 'recepcion', 'cantina'];
    }

    function isActiveUser() {
      return hasUserProfile()
        && userDoc().data.isActive == true
        && isKnownRole(role());
    }

    function hasRole(allowedRoles) {
      return isActiveUser() && role() in allowedRoles;
    }

    function isOwnerOrAdmin() {
      return hasRole(['admin']);
    }

    function isPartner() {
      return hasRole(['socio']);
    }

    function isEventManager() {
      return hasRole(['encargado_eventos']);
    }

    function isReception() {
      return hasRole(['recepcion']);
    }

    function isCanteen() {
      return hasRole(['cantina']);
    }

    function canOperateBase() {
      return isActiveUser();
    }

    function canViewFinance() {
      return isOwnerOrAdmin() || isPartner();
    }

    function canManageClients() {
      return isOwnerOrAdmin() || isPartner() || isReception() || isEventManager();
    }

    function canReadVisits() {
      return isOwnerOrAdmin() || isPartner() || isReception() || isCanteen() || isEventManager();
    }

    function canCreateVisits() {
      return isOwnerOrAdmin() || isPartner() || isReception();
    }

    function canUpdateVisits() {
      return isOwnerOrAdmin() || isPartner() || isReception() || isCanteen();
    }

    function canDeleteActiveVisits() {
      return isOwnerOrAdmin() || isPartner() || isReception();
    }

    function canReadEvents() {
      return isOwnerOrAdmin() || isPartner() || isEventManager() || isReception() || isCanteen();
    }

    function canManageEvents() {
      return isOwnerOrAdmin() || isPartner() || isEventManager();
    }

    function canRegisterEventGuests() {
      return canManageEvents() || isReception();
    }

    function receptionEventCounterUpdateIsSafe() {
      return isReception()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'registeredGuestsCount', 'updatedAt', 'updatedBy'
        ]);
    }

    function canReadCanteen() {
      return isOwnerOrAdmin() || isPartner() || isReception() || isCanteen() || isEventManager();
    }

    function canOperateCanteen() {
      return isOwnerOrAdmin() || isPartner() || isReception() || isCanteen();
    }

    function canManageCanteenInventory() {
      return isOwnerOrAdmin() || isPartner();
    }

    function canReadEventFinance() {
      return canViewFinance() || isEventManager();
    }

    function canRegisterExpense() {
      return isActiveUser();
    }

    function canManageTasks() {
      return isOwnerOrAdmin() || isPartner() || isEventManager();
    }

    function canManageEventBudgets() {
      return isOwnerOrAdmin() || isPartner() || isEventManager();
    }

    function canManageBudgetConfig() {
      return isOwnerOrAdmin() || isPartner();
    }

    function canManageBackups() {
      return isOwnerOrAdmin() || isPartner();
    }

    function isAssignedTask() {
      return isActiveUser()
        && (
          resource.data.assignedTo == request.auth.uid
          || resource.data.assignedTo == request.auth.token.email
        );
    }

    function validUserProfile(uid) {
      return request.resource.data.uid == uid
        && request.resource.data.isActive is bool
        && isKnownRole(request.resource.data.role);
    }

    function validNewUserProfile(uid) {
      return validUserProfile(uid)
        && request.resource.data.keys().hasOnly([
          'uid', 'displayName', 'email', 'role', 'isActive',
          'createdAt', 'createdByUid', 'createdByName',
          'updatedAt', 'updatedBy', 'updatedByName'
        ]);
    }

    function adminUserUpdateIsSafe(uid) {
      return isOwnerOrAdmin()
        && validUserProfile(uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'displayName', 'email', 'role', 'isActive',
          'updatedAt', 'updatedBy', 'updatedByName'
        ])
        && (
          request.auth.uid != uid
          || request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'displayName', 'email', 'updatedAt', 'updatedBy', 'updatedByName'
          ])
        );
    }

    function clientVisitCreateIsSafe() {
      return canCreateVisits()
        && request.resource.data.status == 'active'
        && request.resource.data.planId in ['one-hour', 'two-hours', 'unlimited']
        && (!request.resource.data.keys().hasAny(['customAmount']) || request.resource.data.customAmount == false)
        && (
          request.resource.data.planId == 'one-hour'
            && (!request.resource.data.keys().hasAny(['amountCharged']) || request.resource.data.amountCharged == 60000)
            && (!request.resource.data.keys().hasAny(['parkChargeAmount']) || request.resource.data.parkChargeAmount == 60000)
          || request.resource.data.planId == 'two-hours'
            && (!request.resource.data.keys().hasAny(['amountCharged']) || request.resource.data.amountCharged == 100000)
            && (!request.resource.data.keys().hasAny(['parkChargeAmount']) || request.resource.data.parkChargeAmount == 100000)
          || request.resource.data.planId == 'unlimited'
            && (!request.resource.data.keys().hasAny(['amountCharged']) || request.resource.data.amountCharged == null || request.resource.data.amountCharged == 0)
            && (!request.resource.data.keys().hasAny(['parkChargeAmount']) || request.resource.data.parkChargeAmount == null || request.resource.data.parkChargeAmount == 0)
        )
        && (!request.resource.data.keys().hasAny(['extensionChargeAmount']) || request.resource.data.extensionChargeAmount == 0)
        && (!request.resource.data.keys().hasAny(['timeExtensions']) || request.resource.data.timeExtensions.size() == 0)
        && (!request.resource.data.keys().hasAny(['paymentStatus']) || request.resource.data.paymentStatus != 'paid')
        && (!request.resource.data.keys().hasAny(['paidParkAmount']) || request.resource.data.paidParkAmount == 0)
        && (!request.resource.data.keys().hasAny(['parkPaymentStatus']) || request.resource.data.parkPaymentStatus == 'pending')
        && (!request.resource.data.keys().hasAny(['parkPaidAt']) || request.resource.data.parkPaidAt == null)
        && (!request.resource.data.keys().hasAny(['sourceIntegrity']));
    }

    function clientVisitUpdateIsSafe() {
      return canUpdateVisits()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'amountCharged', 'parkChargeAmount', 'paidParkAmount', 'extensionChargeAmount',
          'paymentStatus', 'paymentMethod', 'cardType', 'parkPaymentStatus', 'parkPaidAt',
          'parkPaymentMethod', 'timeExtensions', 'expectedEndAt', 'durationMinutes',
          'status', 'endedAt', 'realDurationMinutes', 'sourceIntegrity',
          'groupEntryId', 'planId', 'planName', 'isUnlimited', 'defaultAmount',
          'customAmount', 'startedAt'
        ]);
    }

    function eventFinanceUpdateIsSafe() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'eventPaidAmount', 'pendingAmount', 'financialStatus', 'financialUpdatedByBackend'
      ]);
    }

    match /users/{uid} {
      allow read: if signedIn()
        && (
          request.auth.uid == uid
          || isOwnerOrAdmin()
          || isPartner()
          || isEventManager()
        );
      allow create: if isOwnerOrAdmin() && validNewUserProfile(uid);
      allow update: if adminUserUpdateIsSafe(uid);
      allow delete: if false;
    }

    match /customers/{customerId} {
      allow read, create, update: if canManageClients();
      allow delete: if false;
    }

    match /children/{childId} {
      allow read, create, update: if canManageClients();
      allow delete: if false;
    }

    match /activeVisits/{visitId} {
      allow read: if canReadVisits();
      allow create: if clientVisitCreateIsSafe();
      allow update: if clientVisitUpdateIsSafe();
      allow delete: if canDeleteActiveVisits();
    }

    function eventCreateIsSafe() {
      return canManageEvents()
        && (!request.resource.data.keys().hasAny(['eventPaidAmount']) || request.resource.data.eventPaidAmount == 0)
        && (!request.resource.data.keys().hasAny(['financialStatus']) || request.resource.data.financialStatus != 'paid')
        && (!request.resource.data.keys().hasAny(['financialUpdatedByBackend']));
    }

    match /visits/{visitId} {
      allow read: if canReadVisits();
      allow create: if clientVisitCreateIsSafe();
      allow update: if clientVisitUpdateIsSafe();
      allow delete: if false;
    }

    match /events/{eventId} {
      allow read: if canReadEvents();
      allow create: if eventCreateIsSafe();
      allow update: if (canManageEvents() && eventFinanceUpdateIsSafe()) || receptionEventCounterUpdateIsSafe();
      allow delete: if false;
    }

    match /eventGuests/{guestId} {
      allow read: if canReadEvents();
      allow create, update: if canRegisterEventGuests();
      allow delete: if false;
    }

    match /canteenCategories/{categoryId} {
      allow read: if canReadCanteen();
      allow create, update, delete: if canManageCanteenInventory();
    }

    match /canteenProducts/{productId} {
      allow read: if canReadCanteen();
      allow create, update, delete: if false;
    }

    match /canteenOrders/{orderId} {
      allow read: if canReadCanteen();
      allow create, update, delete: if false;
    }

    match /canteenVoidRequests/{requestId} {
      allow read: if canOperateCanteen();
      allow create, update, delete: if false;
    }

    match /canteenInventoryMovements/{movementId} {
      allow read: if isOwnerOrAdmin() || isPartner() || isCanteen();
      allow create, update, delete: if false;
    }

    match /dailyClosings/{closingId} {
      allow read, create, update: if canViewFinance();
      allow delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if canReadEventFinance();
      allow create, update, delete: if false;
    }

    match /expenses/{expenseId} {
      allow read: if canReadEventFinance()
        || (isActiveUser() && resource.data.createdBy == request.auth.uid);
      allow create: if canRegisterExpense()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isOwnerOrAdmin()
        || isPartner()
        || (isActiveUser()
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == resource.data.createdBy);
      allow delete: if false;
    }

    match /financialClosures/{closureId} {
      allow read, create: if canViewFinance();
      allow update: if isOwnerOrAdmin();
      allow delete: if false;
    }

    match /activityLogs/{logId} {
      allow read: if isOwnerOrAdmin() || isPartner();
      allow create: if canOperateBase()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /secureOperations/{operationId} {
      allow read, write: if false;
    }

    match /backups/{backupId} {
      allow read, create: if canManageBackups();
      allow update, delete: if false;
    }

    match /backupLocks/{lockId} {
      allow read, create, update: if canManageBackups();
      allow delete: if false;
    }

    match /tasks/{taskId} {
      allow read: if canManageTasks() || isAssignedTask();
      allow create: if canManageTasks();
      allow update: if canManageTasks()
        || (
          isAssignedTask()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status',
            'completedAt',
            'completedBy',
            'completedByUid',
            'completedByName',
            'updatedAt',
            'updatedBy'
          ])
        );
      allow delete: if false;
    }

    match /settings/{settingId} {
      allow read, create, update: if isOwnerOrAdmin() || isPartner();
      allow delete: if false;
    }

    match /landingContent/{contentId} {
      allow read: if true;
      allow create, update: if isOwnerOrAdmin() || isPartner();
      allow delete: if false;
    }

    match /eventBudgets/{budgetId} {
      allow read, create, update: if canManageEventBudgets();
      allow delete: if false;
    }

    match /budgetGuestPackages/{packageId} {
      allow read: if canManageEventBudgets();
      allow create, update: if canManageBudgetConfig();
      allow delete: if false;
    }

    match /budgetAddons/{addonId} {
      allow read: if canManageEventBudgets();
      allow create, update: if canManageBudgetConfig();
      allow delete: if false;
    }

    match /budgetDecorations/{decorationId} {
      allow read: if canManageEventBudgets();
      allow create, update, delete: if canManageBudgetConfig();
    }

    match /tvDisplaySettings/{settingId} {
      allow read: if canOperateBase();
      allow create, update: if canManageEvents();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
